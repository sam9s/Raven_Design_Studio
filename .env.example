# Raven Design Studio — environment template
# Copy to .env and fill in values. .env is gitignored.
#
# Recommended: use `gh auth login --with-token` instead of storing the GitHub PAT here.
# This file exists only to document the keys the studio MAY reference.

# OpenAI API key — used by Hyperframes CLI for Whisper transcription fallback
# when local whisper.cpp is not installed. Optional.
OPENAI_API_KEY=

# GitHub personal access token — only needed if you prefer env-var auth over
# `gh auth login`. If you use gh auth login, leave this empty.
GITHUB_TOKEN=

# Google Generative AI API key — optional; used by Hyperframes TTS skill.
GOOGLE_API_KEY=
